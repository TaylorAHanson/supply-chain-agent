# Supply Chain Agent Configuration
# Copy this file to .env and update the values to run locally

# The target catalog and schema for your application data
CATALOG_SCHEMA="taylor_hanson_build_catalog.supply_chain_schema"

# The name of the model or AI Gateway route to use
LLM_MODEL_NAME="supply_chain_agent_endpoint"

# Maximum number of tokens for the LLM response
MAX_TOKENS="16384"

# Maximum number of iterations for the LangGraph agent
MAX_ITERATIONS="10"

# The path to the Unity Catalog volume containing your skills markdown files
# Note: The agent will also dynamically discover any other volume named 'skills'
SKILLS_VOLUME_PATH="/Volumes/taylor_hanson_build_catalog/supply_chain_schema/skills"

# The Databricks SQL Warehouse ID used for executing queries (e.g. for dynamic tool discovery)
DATABRICKS_WAREHOUSE_ID="238e4114cdfd555f"

# The MLflow experiment name for logging traces
MLFLOW_EXPERIMENT_NAME="/Shared/supply_chain_agent"

# Note: For Databricks authentication locally, you should rely on the standard Databricks CLI configuration
# e.g., setting DATABRICKS_PROFILE="myenv" or DATABRICKS_HOST and DATABRICKS_TOKEN
